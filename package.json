{
  "name": "hyacine-ai",
  "private": true,
  "version": "1.2.1",
  "description": "OpenAI-compatible QQ bot management panel with an Electron MMD desktop pet",
  "author": "HYACINE-AI contributors",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "electron/main.js",
  "bin": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test test/*.test.js",
    "check:release": "node scripts/check-release-boundary.js",
    "preview": "vite preview",
    "dev:pet": "node scripts/dev-pet.js",
    "electron:dev": "electron electron/main.js",
    "pack:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "ai.hyacine.desktop",
    "productName": "HYACINE-AI",
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "lib/**/*",
      "server.js",
      "types.js",
      "package.json",
      "!**/*.test.js",
      "!**/.env*",
      "!data/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "ammo.wasm.js",
          "ammo.wasm.wasm",
          "pet-manifest.example.json",
          "pet-manifest.json",
          "character.*",
          "tray_icon.*",
          "models/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "openai": "^6.9.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "three": "0.170.0",
    "vite": "^7.2.4"
  }
}
