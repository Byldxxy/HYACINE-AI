# API Key for AI service (OpenAI-compatible endpoint)
# Copy this file to .env and fill in your key
API_KEY=your-api-key-here

# Backend HTTP/WebSocket endpoint
API_PORT=3001
BIND_HOST=127.0.0.1

# Optional desktop-pet PMX/PMD path under public/
VITE_PET_MODEL_PATH=/models/desktop-pet.pmx

# Optional manifest for VMD motions, morphs and interactions
VITE_PET_MANIFEST_PATH=

# Optional Vite URL used by Electron development mode
VITE_DEV_SERVER_URL=http://localhost:5173
